#!/usr/bin/env bash
# After a commit that touched .ai/, regenerate skill/memory index files,
# refresh .skill-space/ + root files from the updated .ai/ source, and
# create a fixup commit so the just-made commit's own hash lands in the
# Modification history table.
#
# Recursion guard: if the just-made commit is itself an auto-update commit,
# this hook exits immediately.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

LAST_MSG=$(git log -1 --format='%s')
if [[ "$LAST_MSG" == "chore: skill-space auto-update"* ]]; then
  exit 0
fi

# Skip if the just-made commit didn't touch any .ai/ file.
if ! git log -1 --name-only --format='' | grep -qE '^\.ai/'; then
  exit 0
fi

echo "skill-space: post-commit — regenerating indexes and refreshing .skill-space/..."
bash "$REPO_ROOT/.ai/build_indexes.sh"
bash "$REPO_ROOT/.ai/onboard_to_project.sh" --refresh

# Collect every index file that may have been (re)generated.
AUTO_FILES=()
for f in "$REPO_ROOT"/.ai/global_memory/GLOBAL_MEMORY_INDEX.md \
         "$REPO_ROOT"/.ai/skills/SKILLS_INDEX.md; do
  [ -f "$f" ] && AUTO_FILES+=("$f")
done

shopt -s nullglob
for idx in "$REPO_ROOT"/.ai/skills/*/memory/MEMORY_INDEX.md; do
  AUTO_FILES+=("$idx")
done
shopt -u nullglob

[ ${#AUTO_FILES[@]} -gt 0 ] && git add "${AUTO_FILES[@]}"

if git diff --cached --quiet; then
  echo "skill-space: indexes already current — no fixup commit needed."
  exit 0
fi

ORIG_HASH=$(git rev-parse --short HEAD)
git commit -m "chore: skill-space auto-update after $ORIG_HASH"
